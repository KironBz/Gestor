<Window x:Class="Yes_Gestor.DialogoCuenta"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cuenta" Height="300" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Border Background="White" CornerRadius="20" Padding="10">
        <StackPanel Margin="10">
            <TextBlock Text="Nombre:" Margin="0,5"/>
            <TextBox x:Name="txtNombre" />
            <TextBlock Text="Visibilidad:" Margin="0,10,0,5"/>
            <ComboBox x:Name="cbVisibilidad" SelectedIndex="0">
                <ComboBoxItem>Corriente</ComboBoxItem>
                <ComboBoxItem>Oculto</ComboBoxItem>
                <ComboBoxItem>Ajeno</ComboBoxItem>
            </ComboBox>
            <TextBlock Text="Saldo inicial:" Margin="0,10,0,5"/>
            <TextBox x:Name="txtSaldoInicial" Text="0" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                <Button Content="Aceptar" Width="80" Click="Aceptar_Click" Style="{StaticResource BotonRedondo}"/>
                <Button Content="Cancelar" Width="80" Margin="10,0,0,0" Click="Cancelar_Click" Style="{StaticResource BotonRedondo}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>