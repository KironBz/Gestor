<Window x:Class="Yes_Gestor.DialogoMeta"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva meta" Height="350" Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Border Background="White" CornerRadius="20" Padding="10">
        <StackPanel Margin="10">
            <TextBlock Text="Nombre de la meta:" Margin="0,5"/>
            <TextBox x:Name="txtNombre" />
            <TextBlock Text="Monto objetivo:" Margin="0,10,0,5"/>
            <TextBox x:Name="txtMontoObjetivo" />
            <TextBlock Text="Prioridad (1 = más urgente):" Margin="0,10,0,5"/>
            <TextBox x:Name="txtPrioridad" Text="1"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                <Button Content="Aceptar" Width="80" Click="Aceptar_Click" Style="{StaticResource BotonRedondo}"/>
                <Button Content="Cancelar" Width="80" Margin="10,0,0,0" Click="Cancelar_Click" Style="{StaticResource BotonRedondo}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>