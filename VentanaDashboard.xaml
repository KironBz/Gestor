<Window x:Class="Yes_Gestor.VentanaDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard" Height="700" Width="1000"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">

    <Border Background="White" CornerRadius="20" Padding="10" BorderBrush="#DDD" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra de título con navegación -->
            <Border Grid.Row="0" Background="#2E8B57" CornerRadius="15,15,0,0" Height="40"
                    MouseLeftButtonDown="MoverVentana_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Balance" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirBalance_Click" FontSize="14" Margin="0,0,20,0"/>
                    <Button Content="Movimientos" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirMovimientos_Click" FontSize="14" Margin="0,0,20,0"/>
                    <Button Content="Préstamos" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirPrestamos_Click" FontSize="14" Margin="0,0,20,0"/>
                    <TextBlock Text="Dashboard" Foreground="White" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Contenido: Aquí irán los gráficos -->
            <ScrollViewer Grid.Row="1" Margin="10">
                <StackPanel>
                    <TextBlock Text="Dashboard (en construcción)" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                    <!-- Ejemplo de gráfico de barras simple (lo remplazaremos después) -->
                    <lvc:CartesianChart Series="{Binding Series}" LegendLocation="Right" Height="300" Margin="0,0,0,20"/>
                    <TextBlock Text="Gráfico de pastel de ingresos vs egresos" FontSize="14" Margin="0,10,0,10"/>
                    <lvc:PieChart Series="{Binding PieSeries}" Height="300"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
