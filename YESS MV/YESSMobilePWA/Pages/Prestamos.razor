@page "/prestamos"
@using YESSMobilePWA.Models
@using YESSMobilePWA.Services
@inject ArchivoService ArchivoService
@inject IJSRuntime JS

<h3>Préstamos y deudas</h3>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="CargarDeudas">Refrescar</button>
</div>

@if (acreedores == null || deudores == null || completados == null)
{
    <p>Cargando...</p>
}
else
{
    <!-- ================================================================ -->
    <!-- DEUDORES (me deben) - Tabla para PC -->
    <!-- ================================================================ -->
    <div class="d-none d-md-block">
        <h5 class="text-warning mt-3">Deudores (me deben)</h5>
        <table class="table table-dark table-striped">
            <thead>
                <tr>
                    <th>Contraparte</th>
                    <th>Monto total</th>
                    <th>Abonado</th>
                    <th>Saldo pendiente</th>
                    <th>Progreso</th>
                    <th>Referencia</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var deuda in deudores)
                {
                    <tr>
                        <td>@deuda.Contraparte</td
                        <td>@deuda.MontoTotal.ToString("C")</td
                        <td>@deuda.Pagado.ToString("C")</td
                        <td>@deuda.SaldoPendiente.ToString("C")</td
                        <td>
                            @if (deuda.PlazosTotales.HasValue)
                            {
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar bg-info" role="progressbar"
                                         style="width: @(Math.Round((double)deuda.PagosRealizados / (double)deuda.PlazosTotales.Value * 100))%;"
                                         aria-valuenow="@deuda.PagosRealizados" aria-valuemin="0" aria-valuemax="@deuda.PlazosTotales.Value">
                                        @deuda.PagosRealizados / @deuda.PlazosTotales
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar bg-success" role="progressbar"
                                         style="width: @(Math.Round((double)deuda.Pagado / (double)deuda.MontoTotal * 100))%;"
                                         aria-valuenow="@deuda.Pagado" aria-valuemin="0" aria-valuemax="@deuda.MontoTotal">
                                        @((deuda.Pagado / deuda.MontoTotal).ToString("P0"))
                                    </div>
                                </div>
                            }
                         </td
                        <td>@deuda.ReferenciaAuto</td
                        <td>
                            <button class="btn btn-sm btn-primary" @onclick="() => RegistrarPago(deuda, false)">Registrar abono</button>
                         </td
                    </tr>
                }
            </tbody>
        </table>

        <hr class="my-3" />

        <!-- ACREEDORES (debo) - Tabla para PC -->
        <h5 class="text-danger mt-4">Acreedores (debo)</h5>
        <table class="table table-dark table-striped">
            <thead>
                <tr>
                    <th>Contraparte</th>
                    <th>Monto total</th>
                    <th>Pagado</th>
                    <th>Saldo pendiente</th>
                    <th>Progreso</th>
                    <th>Referencia</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var deuda in acreedores)
                {
                    <tr>
                        <td>@deuda.Contraparte</td
                        <td>@deuda.MontoTotal.ToString("C")</td
                        <td>@deuda.Pagado.ToString("C")</td
                        <td>@deuda.SaldoPendiente.ToString("C")</td
                        <td>
                            @if (deuda.PlazosTotales.HasValue)
                            {
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar bg-danger" role="progressbar"
                                         style="width: @(Math.Round((double)deuda.PagosRealizados / (double)deuda.PlazosTotales.Value * 100))%;"
                                         aria-valuenow="@deuda.PagosRealizados" aria-valuemin="0" aria-valuemax="@deuda.PlazosTotales.Value">
                                        @deuda.PagosRealizados / @deuda.PlazosTotales
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="progress" style="height: 20px;">
                                    <div class="progress-bar bg-warning" role="progressbar"
                                         style="width: @(Math.Round((double)deuda.Pagado / (double)deuda.MontoTotal * 100))%;"
                                         aria-valuenow="@deuda.Pagado" aria-valuemin="0" aria-valuemax="@deuda.MontoTotal">
                                        @((deuda.Pagado / deuda.MontoTotal).ToString("P0"))
                                    </div>
                                </div>
                            }
                         </td
                        <td>@deuda.ReferenciaAuto</td
                        <td>
                            <button class="btn btn-sm btn-primary" @onclick="() => RegistrarPago(deuda, true)">Pagar</button>
                         </td
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- ================================================================ -->
    <!-- VISTA MÓVIL (tarjetas) -->
    <!-- ================================================================ -->
    <div class="d-block d-md-none">
        <h5 class="text-warning mt-3">Deudores (me deben)</h5>
        @foreach (var deuda in deudores)
        {
            <div class="card bg-dark text-white mb-3" style="border-left: 5px solid @deuda.ColorCuenta;">
                <div class="card-body">
                    <h6 class="card-title">@deuda.Contraparte</h6>
                    <p>
                        Total: @deuda.MontoTotal.ToString("C")<br />
                        Abonado: @deuda.Pagado.ToString("C")<br />
                        Pendiente: @deuda.SaldoPendiente.ToString("C")<br />
                        <strong>Referencia:</strong> @deuda.ReferenciaAuto
                    </p>
                    @if (deuda.PlazosTotales.HasValue)
                    {
                        <div class="progress mb-2" style="height: 20px;">
                            <div class="progress-bar bg-info" role="progressbar"
                                 style="width: @(Math.Round((double)deuda.PagosRealizados / (double)deuda.PlazosTotales.Value * 100))%;">
                                @deuda.PagosRealizados / @deuda.PlazosTotales
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="progress mb-2" style="height: 20px;">
                            <div class="progress-bar bg-success" role="progressbar"
                                 style="width: @(Math.Round((double)deuda.Pagado / (double)deuda.MontoTotal * 100))%;">
                                @((deuda.Pagado / deuda.MontoTotal).ToString("P0"))
                            </div>
                        </div>
                    }
                    <button class="btn btn-sm btn-primary" @onclick="() => RegistrarPago(deuda, false)">Registrar abono</button>
                </div>
            </div>
        }

        <hr class="my-3" />

        <h5 class="text-danger mt-3">Acreedores (debo)</h5>
        @foreach (var deuda in acreedores)
        {
            <div class="card bg-dark text-white mb-3" style="border-left: 5px solid @deuda.ColorCuenta;">
                <div class="card-body">
                    <h6 class="card-title">@deuda.Contraparte</h6>
                    <p>
                        Total: @deuda.MontoTotal.ToString("C")<br />
                        Pagado: @deuda.Pagado.ToString("C")<br />
                        Pendiente: @deuda.SaldoPendiente.ToString("C")<br />
                        <strong>Referencia:</strong> @deuda.ReferenciaAuto
                    </p>
                    @if (deuda.PlazosTotales.HasValue)
                    {
                        <div class="progress mb-2" style="height: 20px;">
                            <div class="progress-bar bg-danger" role="progressbar"
                                 style="width: @(Math.Round((double)deuda.PagosRealizados / (double)deuda.PlazosTotales.Value * 100))%;">
                                @deuda.PagosRealizados / @deuda.PlazosTotales
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="progress mb-2" style="height: 20px;">
                            <div class="progress-bar bg-warning" role="progressbar"
                                 style="width: @(Math.Round((double)deuda.Pagado / (double)deuda.MontoTotal * 100))%;">
                                @((deuda.Pagado / deuda.MontoTotal).ToString("P0"))
                            </div>
                        </div>
                    }
                    <button class="btn btn-sm btn-primary" @onclick="() => RegistrarPago(deuda, true)">Pagar</button>
                </div>
            </div>
        }
    </div>

    <!-- ================================================================ -->
    <!-- PRÉSTAMOS COMPLETADOS -->
    <!-- ================================================================ -->
    <hr class="my-4" />
    <h4 class="text-success">Préstamos completados</h4>

    <div class="d-none d-md-block">
        <table class="table table-dark table-striped">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Tipo</th>
                    <th>Contraparte</th>
                    <th>Referencia</th>
                    <th>Monto total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in completados)
                {
                    <tr>
                        <td>@item.FechaCompletado?.ToString("dd/MM/yyyy")</td
                        <td>@(item.Tipo == "Acreedor" ? "Deuda pagada" : "Préstamo cobrado")</td
                        <td>@item.Contraparte</td
                        <td>@item.ReferenciaAuto</td
                        <td>@item.MontoTotal.ToString("C")</td
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-block d-md-none">
        @foreach (var item in completados)
        {
            <div class="card bg-dark text-white mb-3" style="border-left: 5px solid @item.ColorCuenta;">
                <div class="card-body">
                    <h6 class="card-title">@item.Contraparte</h6>
                    <p>
                        Fecha: @item.FechaCompletado?.ToString("dd/MM/yyyy")<br />
                        Tipo: @(item.Tipo == "Acreedor" ? "Deuda pagada" : "Préstamo cobrado")<br />
                        Referencia: @item.ReferenciaAuto<br />
                        Monto: @item.MontoTotal.ToString("C")
                    </p>
                </div>
            </div>
        }
    </div>
}

<!-- ================================================================ -->
<!-- MODAL PARA REGISTRAR PAGO / ABONO -->
<!-- ================================================================ -->
@if (modalVisible)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white">
                <div class="modal-header">
                    <h5 class="modal-title">Registrar @(esPagoPropio ? "pago" : "abono")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => modalVisible = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Monto</label>
                        <input type="number" step="0.01" min="0.01" class="form-control" @bind="montoPago" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Fecha</label>
                        <input type="date" class="form-control" @bind="fechaPago" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Cuenta</label>
                        <select class="form-select" @bind="cuentaIdPago">
                            <option value="">Seleccione cuenta</option>
                            @foreach (var cuenta in cuentasDisponibles)
                            {
                                <option value="@cuenta.Id">@cuenta.Nombre</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => modalVisible = false">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="GuardarPago">Guardar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // =================================================================
    // VARIABLES PRIVADAS
    // =================================================================
    private List<DeudaPendiente>? acreedores;
    private List<DeudaPendiente>? deudores;
    private List<DeudaPendiente>? completados;
    private List<Cuenta> cuentasDisponibles = new();

    private bool modalVisible = false;
    private DeudaPendiente? deudaSeleccionada;
    private bool esPagoPropio;
    private decimal montoPago;
    private DateTime fechaPago = DateTime.Today;
    private string cuentaIdPago = "";

    private Dictionary<string, Persona> mapaPersonas = new();
    private Dictionary<string, Cuenta> mapaCuentas = new();

    // =================================================================
    // CICLO DE VIDA Y CARGA
    // =================================================================
    protected override async Task OnInitializedAsync()
    {
        await CargarDeudas();
    }

    private async Task CargarDeudas()
    {
        var datos = await ArchivoService.CargarAsync();
        PrecalcularMapas(datos);
        cuentasDisponibles = datos.Cuentas.ToList();
        (acreedores, deudores, completados) = CalcularDeudasCompletas(datos);
        StateHasChanged();
    }

    private void PrecalcularMapas(DatosApp datos)
    {
        mapaPersonas = datos.Personas.ToDictionary(p => p.Id, p => p);
        mapaCuentas = datos.Cuentas.ToDictionary(c => c.Id, c => c);
    }

    // =================================================================
    // CÁLCULO DE DEUDAS (OPTIMIZADO)
    // =================================================================
    private (List<DeudaPendiente> acreedores, List<DeudaPendiente> deudores, List<DeudaPendiente> completados) CalcularDeudasCompletas(DatosApp datos)
    {
        var acreedoresList = new List<DeudaPendiente>();
        var deudoresList = new List<DeudaPendiente>();
        var completadosList = new List<DeudaPendiente>();

        // Precalcular pagos/abonos agrupados por referencia (usando ! para evitar string? como clave)
        var pagosPorReferencia = datos.Movimientos
            .Where(m => m.Tipo == "Egreso" && m.Categoria == "Pago" && !string.IsNullOrEmpty(m.ReferenciaAuto))
            .GroupBy(m => m.ReferenciaAuto!)
            .ToDictionary(g => g.Key, g => new { Total = g.Sum(m => m.Monto), Count = g.Count(), Ultimo = g.Max(m => m.FechaOcurrido) });

        var abonosPorReferencia = datos.Movimientos
            .Where(m => m.Tipo == "Ingreso" && m.Categoria == "Abono" && !string.IsNullOrEmpty(m.ReferenciaAuto))
            .GroupBy(m => m.ReferenciaAuto!)
            .ToDictionary(g => g.Key, g => new { Total = g.Sum(m => m.Monto), Count = g.Count(), Ultimo = g.Max(m => m.FechaOcurrido) });

        // Préstamos recibidos (debo)
        var prestamosRecibidos = datos.Movimientos
            .Where(m => m.Tipo == "Ingreso" && m.Categoria == "Préstamo" && m.PersonaId != null && !string.IsNullOrEmpty(m.ReferenciaAuto))
            .ToList();

        foreach (var prestamo in prestamosRecibidos)
        {
            if (!mapaPersonas.TryGetValue(prestamo.PersonaId!, out var persona)) continue;
            if (!mapaCuentas.TryGetValue(prestamo.CuentaId, out var cuenta)) continue;

            var pagoInfo = pagosPorReferencia.GetValueOrDefault(prestamo.ReferenciaAuto!);
            decimal pagado = pagoInfo?.Total ?? 0;
            int pagosRealizados = pagoInfo?.Count ?? 0;
            decimal montoOriginal = prestamo.MontoFinal ?? prestamo.Monto;
            decimal pendiente = montoOriginal - pagado;

            var deuda = new DeudaPendiente
            {
                Contraparte = persona.Nombre,
                MontoTotal = montoOriginal,
                Pagado = pagado,
                SaldoPendiente = pendiente,
                ReferenciaAuto = prestamo.ReferenciaAuto!,
                PersonaId = prestamo.PersonaId!,
                PagosRealizados = pagosRealizados,
                PlazosTotales = prestamo.Plazos,
                ColorCuenta = cuenta.Color,
                Tipo = "Acreedor"
            };

            if (pendiente > 0)
                acreedoresList.Add(deuda);
            else if (pendiente == 0 && pagado > 0)
            {
                deuda.FechaCompletado = pagoInfo?.Ultimo;
                completadosList.Add(deuda);
            }
        }

        // Préstamos otorgados (me deben)
        var prestamosOtorgados = datos.Movimientos
            .Where(m => m.Tipo == "Egreso" && m.Categoria == "Cargo" && m.PersonaId != null && !string.IsNullOrEmpty(m.ReferenciaAuto))
            .ToList();

        foreach (var prestamo in prestamosOtorgados)
        {
            if (!mapaPersonas.TryGetValue(prestamo.PersonaId!, out var persona)) continue;
            if (!mapaCuentas.TryGetValue(prestamo.CuentaId, out var cuenta)) continue;

            var abonoInfo = abonosPorReferencia.GetValueOrDefault(prestamo.ReferenciaAuto!);
            decimal abonado = abonoInfo?.Total ?? 0;
            int abonosRealizados = abonoInfo?.Count ?? 0;
            decimal montoOriginal = prestamo.MontoFinal ?? prestamo.Monto;
            decimal pendiente = montoOriginal - abonado;

            var deuda = new DeudaPendiente
            {
                Contraparte = persona.Nombre,
                MontoTotal = montoOriginal,
                Pagado = abonado,
                SaldoPendiente = pendiente,
                ReferenciaAuto = prestamo.ReferenciaAuto!,
                PersonaId = prestamo.PersonaId!,
                PagosRealizados = abonosRealizados,
                PlazosTotales = prestamo.Plazos,
                ColorCuenta = cuenta.Color,
                Tipo = "Deudor"
            };

            if (pendiente > 0)
                deudoresList.Add(deuda);
            else if (pendiente == 0 && abonado > 0)
            {
                deuda.FechaCompletado = abonoInfo?.Ultimo;
                completadosList.Add(deuda);
            }
        }

        completadosList = completadosList.OrderByDescending(c => c.FechaCompletado).ToList();
        return (acreedoresList, deudoresList, completadosList);
    }

    // =================================================================
    // MODAL DE PAGO
    // =================================================================
    private void RegistrarPago(DeudaPendiente deuda, bool esPago)
    {
        deudaSeleccionada = deuda;
        esPagoPropio = esPago;
        montoPago = 0;
        fechaPago = DateTime.Today;
        cuentaIdPago = "";
        modalVisible = true;
    }

    private async Task GuardarPago()
    {
        if (string.IsNullOrEmpty(cuentaIdPago))
        {
            await JS.InvokeVoidAsync("alert", "Seleccione una cuenta.");
            return;
        }
        if (montoPago <= 0)
        {
            await JS.InvokeVoidAsync("alert", "El monto debe ser mayor a cero.");
            return;
        }
        if (deudaSeleccionada == null) return;

        if (montoPago > deudaSeleccionada.SaldoPendiente)
        {
            if (!await JS.InvokeAsync<bool>("confirm", $"El monto ingresado ({montoPago:C}) es mayor al saldo pendiente ({deudaSeleccionada.SaldoPendiente:C}). ¿Desea registrarlo de todas formas? Esto podría sobrepagar la deuda."))
                return;
        }

        var datos = await ArchivoService.CargarAsync();

        string tipo = esPagoPropio ? "Egreso" : "Ingreso";
        string categoria = esPagoPropio ? "Pago" : "Abono";
        string descripcion = $"{categoria} de {deudaSeleccionada.Contraparte} - {deudaSeleccionada.ReferenciaAuto}";

        var movimiento = new Movimiento(
            fechaOcurrido: fechaPago,
            tipo: tipo,
            categoria: categoria,
            cuentaId: cuentaIdPago,
            categoriaId: null,
            monto: montoPago,
            personaId: deudaSeleccionada.PersonaId,
            descripcion: descripcion,
            montoFinal: null,
            plazos: null,
            metaId: null
        );
        movimiento.ReferenciaAuto = deudaSeleccionada.ReferenciaAuto;

        datos.Movimientos.Add(movimiento);
        await ArchivoService.GuardarAsync(datos);
        await CargarDeudas();
        modalVisible = false;

        await JS.InvokeVoidAsync("alert", $"{categoria} registrado correctamente.");
    }
}