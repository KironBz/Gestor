<Window x:Class="Yes_Gestor.VentanaMetas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Metas de ahorro" Height="805" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border Background="White" CornerRadius="20" Padding="10" BorderBrush="#DDD" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra de título con navegación -->
            <Border Grid.Row="0" Background="#2E8B57" CornerRadius="15,15,0,0" Height="40"
                    MouseLeftButtonDown="MoverVentana_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Balance" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirBalance_Click" FontSize="14" Margin="0,0,20,0"/>
                    <Button Content="Movimientos" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirMovimientos_Click" FontSize="14" Margin="0,0,20,0"/>
                    <Button Content="Préstamos" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirPrestamos_Click" FontSize="14" Margin="0,0,20,0"/>
                    <Button Content="Dashboard" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirDashboard_Click" FontSize="14" Margin="0,0,20,0"/>
                    <TextBlock Text="Metas de ahorro" Foreground="White" FontSize="16" FontWeight="Bold"/>
                    <Button Content="Configuración" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" Click="AbrirConfiguracion_Click" FontSize="14" Margin="10,0,20,0"/>
                </StackPanel>
            </Border>

            <!-- Contenido principal -->
            <ScrollViewer Grid.Row="1" Margin="10">
                <StackPanel>
                    <!-- Meta Principal -->
                    <Border BorderBrush="#2E8B57" BorderThickness="2" CornerRadius="15" Padding="15" Margin="0,0,0,20" Background="#F0FFF0">
                        <StackPanel>
                            <TextBlock Text="META PRINCIPAL" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" TextAlignment="Center"/>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="txtMetaNombre" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock x:Name="txtMetaObjetivo" FontSize="14" Foreground="Gray"/>
                                    <TextBlock x:Name="txtMetaAhorrado" FontSize="14" Margin="0,5,0,0"/>
                                    <ProgressBar x:Name="pbMetaPrincipal" Height="20" Minimum="0" Maximum="100" Value="0" Foreground="#2E8B57" Margin="0,10,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Content="Completar" Width="100" Margin="0,5" Click="CompletarMetaPrincipal_Click" Style="{StaticResource BotonRedondo}"/>
                                    <Button Content="Archivar" Width="100" Margin="0,5" Click="ArchivarMetaPrincipal_Click" Style="{StaticResource BotonRedondo}" Background="#888"/>
                                    <Button Content="Editar" Width="100" Margin="0,5" Click="EditarMetaPrincipal_Click" Style="{StaticResource BotonRedondo}" Background="#4682B4"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Botones para agregar nueva meta -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,10">
                        <Button Content="Nueva meta" Style="{StaticResource BotonRedondo}" Width="120" Click="NuevaMeta_Click"/>
                    </StackPanel>

                    <!-- Lista de otras metas activas -->
                    <TextBlock Text="Otras metas activas" FontWeight="Bold" FontSize="16" Margin="0,10,0,5"/>
                    <DataGrid x:Name="dgMetasActivas" AutoGenerateColumns="False" IsReadOnly="True" Height="250"
                              SelectionMode="Single" SelectionUnit="FullRow" Margin="0,0,0,15">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="150"/>
                            <DataGridTextColumn Header="Objetivo" Binding="{Binding MontoObjetivo, StringFormat=C}" Width="100"/>
                            <DataGridTextColumn Header="Ahorrado" Binding="{Binding AhorradoActual, StringFormat=C}" Width="100"/>
                            <DataGridTemplateColumn Header="Progreso" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ProgressBar Value="{Binding AhorradoActual}" Maximum="{Binding MontoObjetivo}" Height="15" Foreground="#2E8B57"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Prioridad" Binding="{Binding Prioridad}" Width="70"/>
                            <DataGridTemplateColumn Header="Acciones" Width="225">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Cursor="">
                                            <Button Content="Completar" Width="70" Tag="{Binding}" Click="CompletarMeta_Click" Style="{StaticResource BotonRedondo}" Margin="0,0,5,0"/>
                                            <Button Content="Archivar" Width="70" Tag="{Binding}" Click="ArchivarMeta_Click" Style="{StaticResource BotonRedondo}" Background="#888"/>
                                            <Button Content="Editar" Width="60" Tag="{Binding}" Click="EditarMeta_Click" Style="{StaticResource BotonRedondo}" Margin="0,0,5,0" Background="#4682B4"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Metas completadas (expandible) -->
                    <Expander Header="Metas completadas" IsExpanded="False" Margin="0,10,0,5">
                        <DataGrid x:Name="dgMetasCompletadas" AutoGenerateColumns="False" IsReadOnly="True" Height="150">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="150"/>
                                <DataGridTextColumn Header="Objetivo" Binding="{Binding MontoObjetivo, StringFormat=C}" Width="100"/>
                                <DataGridTextColumn Header="Lograda el" Binding="{Binding FechaCompletada, StringFormat=dd/MM/yyyy}" Width="120"/>
                                <DataGridTemplateColumn Header="Acciones" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Archivar" Tag="{Binding}" Click="ArchivarMetaCompletada_Click" Style="{StaticResource BotonRedondo}" Background="#888"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Expander>

                    <!-- Metas archivadas (expandible) -->
                    <Expander Header="Metas archivadas" IsExpanded="False" Margin="0,10,0,5">
                        <DataGrid x:Name="dgMetasArchivadas" AutoGenerateColumns="False" IsReadOnly="True" Height="150">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="150"/>
                                <DataGridTextColumn Header="Objetivo" Binding="{Binding MontoObjetivo, StringFormat=C}" Width="100"/>
                                <DataGridTextColumn Header="Archivada el" Binding="{Binding FechaArchivada, StringFormat=dd/MM/yyyy}" Width="120"/>
                                <DataGridTemplateColumn Header="Acciones" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Restaurar" Tag="{Binding}" Click="RestaurarMeta_Click" Style="{StaticResource BotonRedondo}" Margin="0,0,5,0"/>
                                                <Button Content="Eliminar" Tag="{Binding}" Click="EliminarMeta_Click" Style="{StaticResource BotonRedondo}" Background="#B22222"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Expander>

                    
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>