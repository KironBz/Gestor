<Window x:Class="Yes_Gestor.VentanaBalance"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Balance General" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <DropShadowEffect x:Key="DropShadow" BlurRadius="8" ShadowDepth="2" Opacity="0.3"/>
    </Window.Resources>

    <!-- Contenedor principal con bordes redondeados y sombra -->
    <Border Background="White" CornerRadius="20" BorderBrush="#DDD" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- BARRA DE TÍTULO PERSONALIZADA -->
            <Border Grid.Row="0" Background="#2E8B57" CornerRadius="20,20,0,0" Height="40"
                    MouseLeftButtonDown="MoverVentana_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Balance" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,20,0"/>
                    <Button Content="Movimientos" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirMovimientos_Click" FontSize="14" Margin="10,0,20,0"/>
                    <Button Content="Préstamos" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" Click="AbrirPrestamos_Click" FontSize="14" Margin="10,0,20,0"/>
                </StackPanel>
            </Border>

            <!-- CONTENIDO PRINCIPAL (con margen para que no quede debajo de la barra) -->
            <Border Grid.Row="1" Background="White" CornerRadius="0,0,20,20" Padding="10">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <!-- izquierda: tarjetas -->
                        <ColumnDefinition Width="3*"/>
                        <!-- derecha: tablas -->
                    </Grid.ColumnDefinitions>

                    <!-- COLUMNA IZQUIERDA (tarjetas) con scroll -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="5">
                            <!-- Tarjeta Dinero disponible -->
                            <Border Background="#2E8B57" CornerRadius="10" Margin="0,0,0,10" Padding="10" Effect="{StaticResource DropShadow}">
                                <StackPanel>
                                    <TextBlock Text="Dinero disponible" Foreground="White" FontSize="14"/>
                                    <TextBlock x:Name="txtDineroDisponible" Foreground="White" FontSize="24" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- Tarjeta Dinero oculto -->
                            <Border Background="#4682B4" CornerRadius="10" Margin="0,0,0,10" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Dinero oculto" Foreground="White" FontSize="14"/>
                                    <TextBlock x:Name="txtDineroOculto" Foreground="White" FontSize="24" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- Tarjeta Cuentas por cobrar (me deben) -->
                            <Border Background="#CD853F" CornerRadius="10" Margin="0,0,0,10" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Cuentas por cobrar" Foreground="White" FontSize="14"/>
                                    <TextBlock x:Name="txtCuentasPorCobrar" Foreground="White" FontSize="24" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- Tarjeta Cuentas por pagar (debo) -->
                            <Border Background="#B22222" CornerRadius="10" Margin="0,0,0,10" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Cuentas por pagar" Foreground="White" FontSize="14"/>
                                    <TextBlock x:Name="txtCuentasPorPagar" Foreground="White" FontSize="24" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- Tarjeta Total global -->
                            <Border Background="#2F4F4F" CornerRadius="10" Margin="0,0,0,10" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Total global" Foreground="White" FontSize="14"/>
                                    <TextBlock x:Name="txtTotalGlobal" Foreground="White" FontSize="24" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- Tarjeta Transporte -->
                            <Border Background="#18278C" CornerRadius="10" Margin="0,0,0,10" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Transporte" Foreground="White" FontSize="14"/>
                                    <TextBlock x:Name="txtTransporte" Foreground="White" FontSize="24" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- Tarjeta Ajeno (dinero en custodia) -->
                            <Border Background="#D549E3" CornerRadius="10" Margin="0,0,0,10" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Ajeno" Foreground="White" FontSize="14"/>
                                    <TextBlock x:Name="txtAjeno" Foreground="White" FontSize="24" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- COLUMNA DERECHA (tablas) -->
                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Deudores (me deben)" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>
                        <DataGrid x:Name="dgDeudores" AutoGenerateColumns="False" Height="200" Margin="0,0,0,15">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Contraparte" Binding="{Binding Contraparte}" Width="*"/>
                                <DataGridTextColumn Header="Monto Total" Binding="{Binding MontoTotal, StringFormat=C}" Width="*"/>
                                <DataGridTextColumn Header="Pagado" Binding="{Binding Pagado, StringFormat=C}" Width="*"/>
                                <DataGridTextColumn Header="Saldo pendiente" Binding="{Binding SaldoPendiente, StringFormat=C}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Acreedores (debo)" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>
                        <DataGrid x:Name="dgAcreedores" AutoGenerateColumns="False" Height="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Contraparte" Binding="{Binding Contraparte}" Width="*"/>
                                <DataGridTextColumn Header="Monto Total" Binding="{Binding MontoTotal, StringFormat=C}" Width="*"/>
                                <DataGridTextColumn Header="Pagado" Binding="{Binding Pagado, StringFormat=C}" Width="*"/>
                                <DataGridTextColumn Header="Saldo pendiente" Binding="{Binding SaldoPendiente, StringFormat=C}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                    <!-- Botón flotante (FAB) - esquina inferior derecha -->
                    <Button Grid.ColumnSpan="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,20,20"
                            Width="50" Height="50" Background="#FF5722" Foreground="White" FontSize="24" FontWeight="Bold"
                            BorderThickness="0" ToolTip="Agregar movimiento"
                            Click="AgregarMovimiento_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="25">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        +
                    </Button>
                </Grid>
            </Border>
            
        </Grid>
    </Border>
</Window>