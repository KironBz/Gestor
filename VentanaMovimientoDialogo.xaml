<Window x:Class="Yes_Gestor.VentanaMovimientoDialogo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nuevo movimiento" Height="650" Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <Style x:Key="CampoRedondo" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,2,0,5"/>
            <Setter Property="Height" Value="30"/>
        </Style>
        <Style x:Key="ComboRedondo" TargetType="ComboBox">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,2,0,5"/>
            <Setter Property="Height" Value="30"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="20" Padding="10" BorderBrush="#DDD" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra de título -->
            <Border Grid.Row="0" Background="#2E8B57" CornerRadius="15,15,0,0" Height="40"
                    MouseLeftButtonDown="MoverVentana_MouseLeftButtonDown">
                <TextBlock Text="Nuevo movimiento" Foreground="White" FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Formulario -->
            <ScrollViewer Grid.Row="1" Margin="10">
                <StackPanel>
                    <TextBlock Text="Fecha:" Margin="0,5,0,0"/>
                    <DatePicker x:Name="dpFecha" SelectedDate="{Binding FechaOcurrido}"/>

                    <TextBlock Text="Tipo:" Margin="0,10,0,0"/>
                    <ComboBox x:Name="cbTipo" Style="{StaticResource ComboRedondo}" SelectedValuePath="Tag">
                        <ComboBoxItem Tag="Ingreso">Ingreso</ComboBoxItem>
                        <ComboBoxItem Tag="Egreso">Egreso</ComboBoxItem>
                        <ComboBoxItem Tag="Transferencia">Transferencia</ComboBoxItem>
                    </ComboBox>

                    <TextBlock Text="Cuenta:" Margin="0,10,0,0"/>
                    <ComboBox x:Name="cbCuenta" Style="{StaticResource ComboRedondo}" DisplayMemberPath="Nombre" SelectedValuePath="Id"/>

                    <TextBlock Text="Categoría:" Margin="0,10,0,0"/>
                    <ComboBox x:Name="cbCategoria" Style="{StaticResource ComboRedondo}" DisplayMemberPath="Nombre" SelectedValuePath="Id"/>

                    <TextBlock Text="Persona:" Margin="0,10,0,0"/>
                    <ComboBox x:Name="cbPersona" Style="{StaticResource ComboRedondo}" DisplayMemberPath="Nombre" SelectedValuePath="Id">
                        <ComboBoxItem Tag="">(Ninguna)</ComboBoxItem>
                    </ComboBox>

                    <TextBlock Text="Descripción:" Margin="0,10,0,0"/>
                    <TextBox x:Name="txtDescripcion" Style="{StaticResource CampoRedondo}" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                    <TextBlock Text="Monto:" Margin="0,10,0,0"/>
                    <TextBox x:Name="txtMonto" Style="{StaticResource CampoRedondo}"/>

                    <!-- Panel préstamo -->
                    <StackPanel x:Name="pnlPrestamo" Visibility="Collapsed">
                        <TextBlock Text="Monto final (con intereses):" Margin="0,10,0,0"/>
                        <TextBox x:Name="txtMontoFinal" Style="{StaticResource CampoRedondo}"/>
                        <TextBlock Text="Plazos (meses):" Margin="0,10,0,0"/>
                        <TextBox x:Name="txtPlazos" Style="{StaticResource CampoRedondo}"/>
                    </StackPanel>

                    <!-- Botones redondeados mediante Border -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,15">
                        <Button Width="100" Height="35" Background="#2E8B57" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="Guardar_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            Guardar
                        </Button>
                        <Button Width="100" Height="35" Background="#888" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Margin="10,0,0,0" Click="Cancelar_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            Cancelar
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>