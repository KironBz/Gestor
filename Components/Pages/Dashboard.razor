@page "/dashboard"
@using YESSMobilePWA.Models
@using YESSMobilePWA.Services
@using Radzen
@using Radzen.Blazor
@using System.Globalization
@inject ArchivoService ArchivoService
@inject IJSRuntime JSRuntime

<h3 class="text-center mb-4">Dashboard Financiero</h3>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <label class="form-label">Año:</label>
        <select class="form-select" @bind="anioSeleccionado">
            <option value="todos">Todos</option>
            @foreach (var anio in aniosDisponibles)
            {
                <option value="@anio">@anio</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <label class="form-label">Período:</label>
        <select class="form-select" @bind="periodoSeleccionado">
            <option value="total">Total histórico</option>
            <option value="semestre1">Semestre 1 (Ene-Jun)</option>
            <option value="semestre2">Semestre 2 (Jul-Dic)</option>
            @for (int i = 1; i <= 12; i++)
            {
                <option value="mes@i">@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option>
            }
        </select>
    </div>
    <div class="col-md-4 d-flex align-items-end">
        <button class="btn btn-primary w-100" @onclick="AplicarFiltros">Filtrar</button>
    </div>
</div>

@if (estaCargando)
{
    <div class="text-center p-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p class="mt-3">Cargando datos financieros...</p>
    </div>
}
else if (!string.IsNullOrEmpty(mensajeError))
{
    <div class="alert alert-danger">
        <strong>Error:</strong> @mensajeError
        <br />
        <small>Revise la consola del navegador (F12) para más detalles.</small>
    </div>
}
else
{
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card bg-dark text-white h-100">
                <div class="card-body">
                    <h5 class="card-title text-center">Ingresos vs Egresos</h5>
                    @if (datosBarras.Any() && datosBarras.Sum(x => x.Monto) > 0)
                    {
                        <RadzenChart Style="height: 300px;">
                            @* <RadzenChartTooltipOptions Shared="true" /> *@  @* Eliminado *@
                            
                            <RadzenColumnSeries TItem="TotalItem"
                                                Data="@datosBarras"
                                                CategoryProperty="Categoria"
                                                ValueProperty="Monto"
                                                Title="Monto Total"
                                                Fills="@paletaColoresBarras" />
                            <RadzenColumnOptions Radius="5" />
                            <RadzenCategoryAxis Padding="20" />
                            
                            <RadzenValueAxis Min="0" Formatter="@FormatearMonedaEje">
                                <RadzenGridLines Visible="true" />
                            </RadzenValueAxis>
                        </RadzenChart>
                    }
                    else
                    {
                        <p class="text-center text-muted py-5">Sin datos</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card bg-dark text-white h-100">
                <div class="card-body">
                    <h5 class="card-title text-center">Proporción Ingresos - Egresos</h5>
                    @if (datosPastelTotal.Any() && datosPastelTotal.Sum(x => x.Monto) > 0)
                    {
                        <RadzenChart Style="height: 300px;">
                            @* <RadzenChartTooltipOptions Shared="false" /> *@  @* Eliminado *@
                            <RadzenPieSeries TItem="TotalItem" 
                                             Data="@datosPastelTotal" 
                                             CategoryProperty="Categoria" 
                                             ValueProperty="Monto"
                                             Fills="@paletaColoresBarras" />
                        </RadzenChart>
                    }
                    else
                    {
                        <p class="text-center text-muted py-5">Sin datos</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card bg-dark text-white h-100">
                <div class="card-body">
                    <h5 class="card-title text-center">Ingresos por Categoría</h5>
                    @if (datosIngresosCategoria.Any() && datosIngresosCategoria.Sum(x => x.Monto) > 0)
                    {
                        <RadzenChart Style="height: 300px;">
                            <RadzenPieSeries TItem="CategoriaItem" 
                                             Data="@datosIngresosCategoria" 
                                             CategoryProperty="Categoria" 
                                             ValueProperty="Monto" />
                        </RadzenChart>
                    }
                    else
                    {
                        <p class="text-center text-muted py-5">Sin ingresos</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card bg-dark text-white h-100">
                <div class="card-body">
                    <h5 class="card-title text-center">Egresos por Categoría</h5>
                    @if (datosEgresosCategoria.Any() && datosEgresosCategoria.Sum(x => x.Monto) > 0)
                    {
                        <RadzenChart Style="height: 300px;">
                            <RadzenPieSeries TItem="CategoriaItem" 
                                             Data="@datosEgresosCategoria" 
                                             CategoryProperty="Categoria" 
                                             ValueProperty="Monto" />
                        </RadzenChart>
                    }
                    else
                    {
                        <p class="text-center text-muted py-5">Sin egresos</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12">
            <div class="card bg-dark text-white">
                <div class="card-body">
                    <h5 class="card-title text-center">Evolución Gastos Mensual</h5>
                    @if (datosLinea.Any() && datosLinea.Any(d => d.Gasto > 0))
                    {
                        <RadzenChart Style="height: 300px;">
                            @* <RadzenChartTooltipOptions Shared="true" /> *@  @* Eliminado *@
                            <RadzenLineSeries TItem="GastoMensual" 
                                              Data="@datosLinea" 
                                              CategoryProperty="Mes" 
                                              ValueProperty="Gasto" />
                            <RadzenCategoryAxis />
                            <RadzenValueAxis Formatter="@FormatearMonedaEje">
                                <RadzenGridLines Visible="true" />
                            </RadzenValueAxis>
                        </RadzenChart>
                    }
                    else
                    {
                        <p class="text-center text-muted py-5">Sin datos</p>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DatosApp? datos;
    private List<int> aniosDisponibles = new();
    private string anioSeleccionado = "todos";
    private string periodoSeleccionado = "total";
    private string? mensajeError;
    private bool estaCargando = true;

    private List<TotalItem> datosBarras = new();
    private List<TotalItem> datosPastelTotal = new();
    private List<CategoriaItem> datosIngresosCategoria = new();
    private List<CategoriaItem> datosEgresosCategoria = new();
    private List<GastoMensual> datosLinea = new();

    private readonly string[] paletaColoresBarras = new string[] { "#28a745", "#dc3545" };

    private string FormatearMonedaEje(object value)
    {
        if (value is double numero)
        {
            return numero.ToString("C0", CultureInfo.GetCultureInfo("es-MX"));
        }
        return value?.ToString() ?? string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            estaCargando = true;
            datos = await ArchivoService.CargarAsync();
            if (datos?.Movimientos != null)
            {
                aniosDisponibles = datos.Movimientos
                    .Where(m => m.Categoria != null && m.Categoria != "Transferencia")
                    .Select(m => m.FechaOcurrido.Year)
                    .Distinct()
                    .OrderBy(a => a)
                    .ToList();
                CalcularMetricas();
            }
            else
            {
                mensajeError = "No se pudieron cargar los datos financieros.";
            }
        }
        catch (Exception ex) 
        { 
            mensajeError = $"Error de infraestructura: {ex.Message}"; 
            Console.WriteLine($"Excepción en OnInitializedAsync: {ex}");
        }
        finally
        {
            estaCargando = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!estaCargando && datos != null)
        {
            // Esperar un poco a que Radzen termine de dibujar
            await Task.Delay(500);
            await JSRuntime.InvokeVoidAsync("initCustomTooltips", 
                datosBarras, datosPastelTotal, datosIngresosCategoria, datosEgresosCategoria, datosLinea);
        }
        await base.OnAfterRenderAsync(firstRender);
    }
    

    private void AplicarFiltros()
    {
        estaCargando = true;
        try
        {
            CalcularMetricas();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error en filtro: {ex.Message}";
        }
        finally
        {
            estaCargando = false;
            StateHasChanged();
        }
    }

    private void CalcularMetricas()
    {
        if (datos?.Movimientos == null) return;

        var movimientos = datos.Movimientos
            .Where(m => !string.IsNullOrEmpty(m.Categoria) && m.Categoria != "Transferencia").ToList();

        if (!movimientos.Any()) { LimpiarDatos(); return; }

        if (anioSeleccionado != "todos" && int.TryParse(anioSeleccionado, out int anioParsed))
        {
            movimientos = movimientos.Where(m => m.FechaOcurrido.Year == anioParsed).ToList();
        }

        if (periodoSeleccionado != "total")
        {
            if (periodoSeleccionado == "semestre1") 
                movimientos = movimientos.Where(m => m.FechaOcurrido.Month <= 6).ToList();
            else if (periodoSeleccionado == "semestre2") 
                movimientos = movimientos.Where(m => m.FechaOcurrido.Month >= 7).ToList();
            else if (periodoSeleccionado.StartsWith("mes") && int.TryParse(periodoSeleccionado.AsSpan(3), out int mes))
            {
                movimientos = movimientos.Where(m => m.FechaOcurrido.Month == mes).ToList();
            }
        }

        if (!movimientos.Any()) { LimpiarDatos(); return; }

        decimal totalIngresos = movimientos.Where(m => m.Tipo == "Ingreso").Sum(m => m.Monto);
        decimal totalEgresos = movimientos.Where(m => m.Tipo == "Egreso").Sum(m => m.Monto);

        datosBarras = new List<TotalItem>
        {
            new() { Categoria = "Ingresos", Monto = (double)totalIngresos },
            new() { Categoria = "Egresos", Monto = (double)totalEgresos }
        };

        datosPastelTotal = datosBarras.Select(x => new TotalItem { Categoria = x.Categoria, Monto = x.Monto }).ToList();

        datosIngresosCategoria = movimientos.Where(m => m.Tipo == "Ingreso")
            .GroupBy(m => m.Categoria)
            .Select(g => new CategoriaItem { Categoria = g.Key ?? "Otros", Monto = (double)g.Sum(m => m.Monto) })
            .OrderByDescending(x => x.Monto).ToList();

        datosEgresosCategoria = movimientos.Where(m => m.Tipo == "Egreso")
            .GroupBy(m => m.Categoria)
            .Select(g => new CategoriaItem { Categoria = g.Key ?? "Otros", Monto = (double)g.Sum(m => m.Monto) })
            .OrderByDescending(x => x.Monto).ToList();

        ConstruirLineaGastos(movimientos);
    }

    private void ConstruirLineaGastos(List<Movimiento> movimientos)
    {
        var lineData = new List<GastoMensual>();
        if (anioSeleccionado != "todos" && int.TryParse(anioSeleccionado, out int anio))
        {
            for (int mes = 1; mes <= 12; mes++)
            {
                decimal gasto = movimientos.Where(m => m.Tipo == "Egreso" && m.FechaOcurrido.Year == anio && m.FechaOcurrido.Month == mes).Sum(m => m.Monto);
                lineData.Add(new GastoMensual { Mes = CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(mes), Gasto = (double)gasto });
            }
        }
        else
        {
            if (!movimientos.Any()) return;
            var fechas = movimientos.Select(m => m.FechaOcurrido).ToList();
            var primera = fechas.Min();
            var ultima = fechas.Max();
            var fecha = new DateTime(primera.Year, primera.Month, 1);
            string formato = (primera.Year == ultima.Year) ? "MMM" : "MM/yy";
            while (fecha <= ultima)
            {
                decimal gasto = movimientos.Where(m => m.Tipo == "Egreso" && m.FechaOcurrido.Year == fecha.Year && m.FechaOcurrido.Month == fecha.Month).Sum(m => m.Monto);
                lineData.Add(new GastoMensual { Mes = fecha.ToString(formato), Gasto = (double)gasto });
                fecha = fecha.AddMonths(1);
            }
        }
        datosLinea = lineData;
    }

    private void LimpiarDatos()
    {
        datosBarras.Clear();
        datosPastelTotal.Clear();
        datosIngresosCategoria.Clear();
        datosEgresosCategoria.Clear();
        datosLinea.Clear();
    }

    public class TotalItem
    {
        public string Categoria { get; set; } = string.Empty;
        public double Monto { get; set; }
    }

    public class CategoriaItem
    {
        public string Categoria { get; set; } = string.Empty;
        public double Monto { get; set; }
    }

    public class GastoMensual
    {
        public string Mes { get; set; } = string.Empty;
        public double Gasto { get; set; }
    }
}