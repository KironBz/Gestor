<Window x:Class="Yes_Gestor.VentanaPrestamos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Préstamos y deudas" Height="625" Width="1000"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border Background="White" CornerRadius="20" Padding="10" BorderBrush="#DDD" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- BARRA DE TÍTULO CON BOTONES DE NAVEGACIÓN -->
            <Border Grid.Row="0" Background="#2E8B57" CornerRadius="15,15,0,0" Height="40"
                    MouseLeftButtonDown="MoverVentana_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Balance" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirBalance_Click" FontSize="14" Margin="0,0,20,0"/>
                    <Button Content="Movimientos" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirMovimientos_Click" FontSize="14" Margin="0,0,20,0"/>
                    <TextBlock Text="Préstamos y deudas" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,20,0"/>
                    <Button Content="Dashboard" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirDashboard_Click" FontSize="14" Margin="10,0,20,0"/>
                    <Button Content="Metas" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirMetas_Click" FontSize="14" Margin="10,0,20,0"/>
                    <Button Content="Configuración" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirConfiguracion_Click" FontSize="14" Margin="10,0,20,0"/>
                </StackPanel>
            </Border>

            <!-- Contenido principal (igual que antes) -->
            <Grid Grid.Row="1" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Panel izquierdo: Deudores (me deben) -->
                <Border Grid.Column="0" Margin="5" BorderBrush="#DDD" BorderThickness="1" CornerRadius="10" Padding="5">
                    <StackPanel>
                        <TextBlock Text="DEUDORES (ME DEBEN)" FontWeight="Bold" FontSize="16" TextAlignment="Center" Margin="0,0,0,10"/>
                        <DataGrid x:Name="dgDeudores" AutoGenerateColumns="False" IsReadOnly="True" Height="400">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Contraparte" Binding="{Binding Contraparte}" Width="*"/>
                                <DataGridTextColumn Header="Monto Total" Binding="{Binding MontoTotal, StringFormat=C}" Width="*"/>
                                <DataGridTextColumn Header="Pagado" Binding="{Binding Pagado, StringFormat=C}" Width="*"/>
                                <DataGridTextColumn Header="Saldo pendiente" Binding="{Binding SaldoPendiente, StringFormat=C}" Width="*"/>
                                <DataGridTextColumn Header="Progreso" Width="80">
                                    <DataGridTextColumn.Binding>
                                        <MultiBinding StringFormat="{}{0}/{1}">
                                            <Binding Path="PagosRealizados"/>
                                            <Binding Path="PlazosTotales"/>
                                        </MultiBinding>
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Cuota mensual" Binding="{Binding CuotaMensual, StringFormat=C}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Content="Registrar pago" Style="{StaticResource BotonRedondo}" Margin="0,10,0,0" Click="RegistrarPagoDeudor_Click"/>
                    </StackPanel>
                </Border>

                <!-- Panel derecho: Acreedores (debo) -->
                <Border Grid.Column="1" Margin="5" BorderBrush="#DDD" BorderThickness="1" CornerRadius="10" Padding="5">
                    <StackPanel>
                        <TextBlock Text="ACREEDORES (DEBO)" FontWeight="Bold" FontSize="16" TextAlignment="Center" Margin="0,0,0,10"/>
                        <DataGrid x:Name="dgAcreedores" AutoGenerateColumns="False" IsReadOnly="True" Height="400">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Contraparte" Binding="{Binding Contraparte}" Width="*"/>
                                <DataGridTextColumn Header="Monto Total" Binding="{Binding MontoTotal, StringFormat=C}" Width="*"/>
                                <DataGridTextColumn Header="Pagado" Binding="{Binding Pagado, StringFormat=C}" Width="*"/>
                                <DataGridTextColumn Header="Saldo pendiente" Binding="{Binding SaldoPendiente, StringFormat=C}" Width="*"/>
                                <DataGridTextColumn Header="Progreso" Width="80">
                                    <DataGridTextColumn.Binding>
                                        <MultiBinding StringFormat="{}{0}/{1}">
                                            <Binding Path="PagosRealizados"/>
                                            <Binding Path="PlazosTotales"/>
                                        </MultiBinding>
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Cuota mensual" Binding="{Binding CuotaMensual, StringFormat=C}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Content="Registrar pago" Style="{StaticResource BotonRedondo}" Margin="0,10,0,0" Click="RegistrarPagoAcreedor_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
            <!-- Botón flotante -->
            <Button Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,20,20"
                Width="50" Height="50" Background="#FF5722" Foreground="White" FontSize="24" FontWeight="Bold"
                BorderThickness="0" ToolTip="Agregar movimiento" Click="AgregarMovimiento_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="25">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                +
            </Button>
        </Grid>
       
    </Border>
</Window>