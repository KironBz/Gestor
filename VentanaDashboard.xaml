<Window x:Class="Yes_Gestor.VentanaDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Dashboard" Height="750" Width="1100"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border Background="White" CornerRadius="20" Padding="10" BorderBrush="#DDD" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra de título con navegación -->
            <Border Grid.Row="0" Background="#2E8B57" CornerRadius="15,15,0,0" Height="40"
                    MouseLeftButtonDown="MoverVentana_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Balance" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirBalance_Click" FontSize="14" Margin="0,0,20,0"/>
                    <Button Content="Movimientos" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirMovimientos_Click" FontSize="14" Margin="0,0,20,0"/>
                    <Button Content="Préstamos" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirPrestamos_Click" FontSize="14" Margin="0,0,20,0"/>
                    <TextBlock Text="Dashboard" Foreground="White" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Contenido principal -->
            <ScrollViewer Grid.Row="1" Margin="10">
                <StackPanel>
                    <!-- Fila superior: gráfico de barras + pastel -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Gráfico de barras (Ingresos vs Egresos por mes) -->
                        <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Ingresos vs Egresos mensuales" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" TextAlignment="Center"/>
                                <lvc:CartesianChart Series="{Binding Series}" LegendLocation="Top" Height="300">
                                    <lvc:CartesianChart.AxisX>
                                        <lvc:Axis Title="Mes" Labels="{Binding EtiquetasMeses}"/>
                                    </lvc:CartesianChart.AxisX>
                                    <lvc:CartesianChart.AxisY>
                                        <lvc:Axis Title="Monto" LabelFormatter="{Binding FormatterMoneda}"/>
                                    </lvc:CartesianChart.AxisY>
                                </lvc:CartesianChart>
                            </StackPanel>
                        </Border>

                        <!-- Gráfico de pastel (Ingresos totales vs Egresos totales) -->
                        <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="10" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Ingresos vs Egresos totales" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" TextAlignment="Center"/>
                                <lvc:PieChart Series="{Binding PieSeries}" Height="300" LegendLocation="Right"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Gráfico de líneas: Evolución de gastos mensuales -->
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="10" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Evolución de gastos mensuales" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" TextAlignment="Center"/>
                            <lvc:CartesianChart Series="{Binding LineSeries}" LegendLocation="Top" Height="300">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Mes" Labels="{Binding EtiquetasGastosMeses}"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="Gasto" LabelFormatter="{Binding FormatterMoneda}"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>