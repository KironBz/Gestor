<Window x:Class="Yes_Gestor.VentanaMovimientos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Movimientos" Height="600" Width="1000"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <!-- Se elimina la definición local de BotonRedondo (ahora está en App.xaml) -->

    <Border Background="White" CornerRadius="20" Padding="10" BorderBrush="#DDD" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra de título -->
            <Border Grid.Row="0" Background="#2E8B57" CornerRadius="15,15,0,0" Height="40"
                    MouseLeftButtonDown="MoverVentana_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Balance" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" 
                            Click="AbrirBalance_Click" FontSize="14" Margin="0,0,20,0"/>
                    <TextBlock Text="Movimientos" Foreground="White" FontSize="16" FontWeight="Bold" Margin="10,0,20,0"/>
                    <Button Content="Préstamos" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" Click="AbrirPrestamos_Click" FontSize="14" Margin="10,0,20,0"/>
                    <Button Content="Dashboard" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" Click="AbrirDashboard_Click" FontSize="14" Margin="10,0,20,0"/>
                    <Button Content="Metas" Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" Click="AbrirMetas_Click" FontSize="14" Margin="10,0,20,0"/>
                </StackPanel>
            </Border>

            <!-- Contenido principal -->
            <Border Grid.Row="1" Background="White" CornerRadius="0,0,15,15">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filtros -->
                    <Border Grid.Row="0" Padding="10" Margin="0,0,0,10" Background="#F5F5F5" CornerRadius="10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock Text="Desde:" VerticalAlignment="Center" Margin="5,0"/>
                            <DatePicker x:Name="dpFechaDesde" Width="100" Margin="5,0"/>
                            <TextBlock Text="Hasta:" VerticalAlignment="Center" Margin="5,0"/>
                            <DatePicker x:Name="dpFechaHasta" Width="100" Margin="5,0"/>

                            <TextBlock Text="Cuenta:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                            <ComboBox x:Name="cbCuentaFiltro" Width="120" DisplayMemberPath="Nombre" SelectedValuePath="Id" Margin="5,0"/>

                            <TextBlock Text="Categoría:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                            <ComboBox x:Name="cbCategoriaFiltro" Width="120" DisplayMemberPath="Nombre" SelectedValuePath="Id" Margin="5,0"/>

                            <Button Content="Filtrar" Style="{StaticResource BotonRedondo}" Width="80" Margin="20,0,0,0" Click="Filtrar_Click"/>
                            <Button Content="Limpiar" Style="{StaticResource BotonRedondo}" Width="80" Margin="10,0,0,0" Click="LimpiarFiltros_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- DataGrid envuelto en Border redondeado -->
                    <Border Grid.Row="1" CornerRadius="10" BorderBrush="#DDD" BorderThickness="1" Margin="0,10,0,10">
                        <DataGrid x:Name="dgMovimientos" AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single" SelectionUnit="FullRow" RowHeaderWidth="0"
                                  BorderThickness="0">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Fecha" Binding="{Binding FechaOcurrido, StringFormat=dd/MM/yyyy}" Width="90"/>
                                <DataGridTextColumn Header="Cuenta" Binding="{Binding NombreCuenta}" Width="120"/>
                                <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="100"/>
                                <DataGridTextColumn Header="Categoría" Binding="{Binding Categoria}" Width="120"/>
                                <DataGridTextColumn Header="Persona" Binding="{Binding NombrePersona}" Width="100"/>
                                <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                                <DataGridTextColumn Header="Monto" Binding="{Binding Monto, StringFormat=C}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Botón flotante -->
                    <Button Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,20,20"
                            Width="50" Height="50" Background="#FF5722" Foreground="White" FontSize="24" FontWeight="Bold"
                            BorderThickness="0" ToolTip="Agregar movimiento" Click="AgregarMovimiento_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="25">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        +
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>